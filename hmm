#!/bin/bash

# Define the path to your python helper script
HELPER_SCRIPT="$HOME/.local/bin/cmdhelper.py"

if [[ "$1" == "-update" ]]; then
    echo "Updating hmm..."
    BASE_URL="https://raw.githubusercontent.com/eloop001/hmm/main"
    INSTALL_DIR="$HOME/.local/bin"
    FILES="hmm gemini.py cmdhelper.py oshelp.md"
    
    mkdir -p "$INSTALL_DIR"
    
    # Use the venv Python path for shebangs
    VENV_PYTHON="$HOME/.local/share/hmm/venv/bin/python"
    
    for FILE in $FILES; do
        echo "  Downloading $FILE ..."
        curl -fsSL "$BASE_URL/$FILE" -o "$INSTALL_DIR/$FILE"
    done
    
    chmod +x "$INSTALL_DIR/hmm" "$INSTALL_DIR/gemini.py" "$INSTALL_DIR/cmdhelper.py"
    
    # Restore shebangs
    if [ -n "$VENV_PYTHON" ] && [ -f "$VENV_PYTHON" ]; then
        echo "Restoring shebangs to use $VENV_PYTHON ..."
        for PYFILE in "$INSTALL_DIR/gemini.py" "$INSTALL_DIR/cmdhelper.py"; do
            if head -1 "$PYFILE" | grep -q '^#!'; then
                if [ "$(uname)" = "Darwin" ]; then
                    sed -i '' "1s|^#!.*|#!$VENV_PYTHON|" "$PYFILE"
                else
                    sed -i "1s|^#!.*|#!$VENV_PYTHON|" "$PYFILE"
                fi
            else
                echo "#!$VENV_PYTHON" > "$PYFILE.tmp"
                cat "$PYFILE" >> "$PYFILE.tmp"
                mv "$PYFILE.tmp" "$PYFILE"
                chmod +x "$PYFILE"
            fi
        done
    fi
    
    echo "Update complete!"
    exit 0
fi

# Check if the first argument is the execute flag
if [[ "$1" == "-x" ]]; then
    # Remove the '-x' flag from the list of arguments
    shift 
    
    # Run the helper script and capture the output into a variable
    GENERATED_CMD=$("$HELPER_SCRIPT" "$@")
    
    if [[ "$GENERATED_CMD" == \#* ]]; then
        printf "\033[31m%s\033[0m\n" "$GENERATED_CMD"
        echo "To run this command manually, copy and paste it into your terminal."
        exit 0
    fi
    
    # Print what is about to be executed (for safety and visibility)
    printf "\033[36mCommand:\033[0m %s\n" "$GENERATED_CMD"
    
    eval "$GENERATED_CMD"
    
else
    # Standard behavior: just run the script and print to console
    "$HELPER_SCRIPT" "$@"
fi